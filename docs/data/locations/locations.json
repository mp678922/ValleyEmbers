[
  {
    "id": "village_square_hub",
    "name": "村莊廣場",
    "sceneType": "hub",
    "description": "你一踏進廣場，就能看見通往宿舍、藥草棚、工坊和開墾區的路都從這裡分出去。空地上沒有多少人，卻留著幾道腳印、木桶拖痕和剛被貼好的紙條，讓你知道大家每天都會從這裡分頭去做事。",
    "impressionInfos": [
      {
        "id": "square_morning_breath",
        "weight": 2,
        "conditions": {
          "timeBlocks": ["清晨", "上午"]
        },
        "text": "廣場還帶著早晨的涼意，幾道腳步聲先後穿過空地。木門開合後，很快又只剩風聲；你能看出幾個女孩已經各自往田地、藥草棚和工坊去了。"
      },
      {
        "id": "square_evening_fragile_warmth",
        "weight": 2,
        "conditions": {
          "timeBlocks": ["傍晚", "夜晚"]
        },
        "text": "廣場的光線慢慢沉下去，說話聲也比白天輕。你看見一兩個熟悉身影從屋邊經過，短暫笑了幾聲，又很快把工具和籃子帶回該放的位置。"
      },
      {
        "id": "square_default",
        "weight": 1,
        "text": "你一踏進廣場，就能看見通往宿舍、藥草棚、工坊和開墾區的路都從這裡分出去。空地上沒有多少人，卻留著幾道腳印、木桶拖痕和剛被貼好的紙條。"
      }
    ],
    "baseCommandSet": "standardLocation",
    "allowPresentVillagers": true,
    "exits": [
      { "to": "dormitory", "label": "前往宿舍", "timeCostSeconds": 180 },
      { "to": "herb_shed", "label": "前往藥草棚", "timeCostSeconds": 180 },
      { "to": "workshop_storage", "label": "前往工坊倉庫", "timeCostSeconds": 180 },
      { "to": "reclamation_area", "label": "前往開墾區", "timeCostSeconds": 240 },
      {
        "to": "forest_edge",
        "label": "離開村莊，前往森林外圍",
        "timeCostSeconds": 600,
        "eventBeforeMove": {
          "eventId": "sela_first_forest_edge_warning"
        }
      }
    ]
